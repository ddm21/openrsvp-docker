# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (Neon)
DATABASE_URL=postgresql://user:password@localhost:5432/rsvp

# BetterAuth
# Use this Site to generate a random hash string: https://generate.plus/en/hash
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth for BetterAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External API for License Verification
# Note: DO NOT add LICENSE_KEY here. The user enters their license key through the Billing UI.
LICENSE_SERVER_URL="https://api.rsvplicense.com"

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Dispatch / Delivery Providers (Email, SMS, WhatsApp)
PLUNK_API_KEY=

# Storage (S3 / Cloudflare R2 / AWS)
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_DOMAIN=

# Coming Soon
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=